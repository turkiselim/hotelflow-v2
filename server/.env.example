# ──────────────────────────────────────────
# TEAMFLOW — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# NE JAMAIS commiter le fichier .env sur GitHub !
# ──────────────────────────────────────────

# Base de données PostgreSQL
# En local : postgresql://USER:PASSWORD@localhost:5432/teamflow
# Sur Render : copiez l'URL depuis votre service PostgreSQL Render
DATABASE_URL="postgresql://teamflow_user:votremotdepasse@localhost:5432/teamflow"

# Secret JWT (clé secrète pour signer les tokens)
# Générez une clé aléatoire : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="remplacez-ceci-par-une-longue-chaine-aleatoire-secrete"
JWT_EXPIRES_IN="7d"

# Port du serveur
PORT=3001

# URL du frontend (pour le CORS)
# En local : http://localhost:5173
# En production : https://votre-app.onrender.com
CLIENT_URL="http://localhost:5173"

# Environnement
NODE_ENV="development"
