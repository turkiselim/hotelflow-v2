// server/prisma/schema.prisma
// Schéma de la base de données TeamFlow

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── UTILISATEURS ───
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  role      Role     @default(MEMBER)
  isOnline  Boolean  @default(false)

  // Relations
  ownedProjects   Project[]  @relation("ProjectOwner")
  memberProjects  Project[]  @relation("ProjectMembers")
  assignedTasks   Task[]     @relation("TaskAssignees")
  comments        Comment[]
  messages        Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PROJETS ───
model Project {
  id          String  @id @default(uuid())
  name        String
  description String?
  color       String  @default("#6c63ff")

  // Relations
  owner     User    @relation("ProjectOwner", fields: [ownerId], references: [id])
  ownerId   String
  members   User[]  @relation("ProjectMembers")
  tasks     Task[]
  messages  Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── TÂCHES ───
model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  status      Status    @default(TODO)
  priority    Priority  @default(NORMAL)
  tag         String?
  department  String?
  progress    Int       @default(0)
  startDate   DateTime?
  dueDate     DateTime?

  // Relations
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  assignees User[]   @relation("TaskAssignees")
  comments  Comment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── COMMENTAIRES ───
model Comment {
  id      String @id @default(uuid())
  content String

  // Relations
  author   User   @relation(fields: [authorId], references: [id])
  authorId String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId   String

  createdAt DateTime @default(now())
}

// ─── MESSAGES DU CHAT ───
model Message {
  id      String @id @default(uuid())
  content String

  // Relations
  author    User    @relation(fields: [authorId], references: [id])
  authorId  String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  createdAt DateTime @default(now())
}

// ─── ENUMS ───
enum Status {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum Priority {
  HIGH
  LOW
  NORMAL
  URGENT
}

enum Role {
  ADMIN
  PROJECT_MANAGER
  MEMBER
}
